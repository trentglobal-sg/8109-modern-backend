<%- contentFor('title') %>
All Customers

<%- contentFor('body') %>
<h1>All Customers</h1>

<table class="table">
    <thead>
        <tr>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Company</th>
        </tr>
    </thead>
    <tbody>
        <% for (let c of customers) { %>
            <tr>
                <td>
                    <%= c.Customers.first_name %>
                </td>
                <td>
                    <%= c.Customers.last_name %>
                </td>
                <td>
                    <%= c.Customers.email %>
                </td>
                <td>
                    <%= c.Companies.name %>
                </td>
            </tr>
            <% } %>
    </tbody>
</table>